// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// criar uma migration: yarn prisma migrate dev
model Person {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  name       String
  cpf        String    @unique
  phone      String
  dt_nasc    DateTime
  sexo       String
  situacao   Boolean   @default(true)
  email      String    @unique
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  user                User? // campo oposto da relação 1:1
  Teacher             Teacher?
  student             Student?
  ClassSessionTeacher ClassSession[] @relation("TeacherClassSessions")
  ClassSessionPerson  ClassSession[] @relation("PersonClassSessions")
  Lesson              Lesson[]

  @@map("person")
}

model User {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  password   String
  role       String    @default("viewer")
  custom_permissions String[] @default([])
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  id_person  Int       @unique
  person     Person    @relation(fields: [id_person], references: [id])

  @@map("user")
}

model Class {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique @default(uuid())
  name           String
  idade_in       Int
  idade_fn       Int
  bo_situacao    Boolean        @default(true) // ativo por padrão
  description    String?        @db.VarChar(500)
  created_at     DateTime       @default(now()) // data atual
  teachers       ClassTeacher[] // relação via pivot
  ClassStudent   ClassStudent[]
  ClassSession   ClassSession[]
  Lesson         Lesson[]
  AcademicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  academicYearId Int?

  @@map("class")
}

model Teacher {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @default(uuid())
  id_person   Int            @unique
  bo_situacao Boolean        @default(true) // ativo por padrão
  created_at  DateTime       @default(now()) // data atual
  person      Person         @relation(fields: [id_person], references: [id])
  classes     ClassTeacher[]

  @@map("teacher")
}

model ClassTeacher {
  id         Int    @id @default(autoincrement())
  uuid       String @unique @default(uuid())
  id_teacher Int
  id_class   Int

  teacher Teacher @relation(fields: [id_teacher], references: [id])
  class   Class   @relation(fields: [id_class], references: [id])

  @@unique([id_teacher, id_class]) // evita duplicados
  @@map("class_teacher")
}

model Student {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  id_person   Int       @unique
  created_at  DateTime? @default(now())
  bo_situacao Boolean   @default(true)

  person  Person         @relation(fields: [id_person], references: [id])
  classes ClassStudent[]

  @@map("student")
}

model ClassStudent {
  id         Int    @id @default(autoincrement())
  uuid       String @unique @default(uuid())
  id_student Int
  id_class   Int

  student Student @relation(fields: [id_student], references: [id])
  class   Class   @relation(fields: [id_class], references: [id])

  @@unique([id_student, id_class])
  @@map("class_student")
}

model ClassSession {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  id_class   Int
  dt_session DateTime
  nr_lesson  Int
  topic      String   @db.VarChar(255)
  id_teacher Int
  notes      String?  @db.VarChar(500)
  id_person  Int

  class   Class  @relation(fields: [id_class], references: [id])
  teacher Person @relation("TeacherClassSessions", fields: [id_teacher], references: [id])
  person  Person @relation("PersonClassSessions", fields: [id_person], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class_session")
}

model Lesson {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  id_class         Int
  dt_lesson        DateTime
  nr_lesson        Int
  title            String   @db.VarChar(255)
  description      String?  @db.VarChar(500)
  id_period        Int
  id_person_create Int
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relacionamentos
  class   Class          @relation(fields: [id_class], references: [id])
  period  AcademicPeriod @relation(fields: [id_period], references: [id])
  creator Person         @relation(fields: [id_person_create], references: [id])

  @@map("lesson")
}

// Ano letivo
model AcademicYear {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  year             Int // ex: 2025
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  id_person_create Int

  periods AcademicPeriod[]
  classes Class[]

  @@map("academic_year")
}

// Período (trimestre, semestre, bimestre)
model AcademicPeriod {
  id               Int      @id @default(autoincrement())
  name             String // ex: "1º Trimestre"
  dt_start         DateTime
  dt_end           DateTime
  id_academy_year  Int
  id_person_create Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [id_academy_year], references: [id])
  lessons      Lesson[]

  @@map("academic_period")
}
