// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// criar uma migration: yarn prisma migrate dev
model Person {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  name       String
  cpf        String    @unique
  phone      String
  dt_nasc    DateTime
  sexo       String
  situacao   Boolean   @default(true)
  email      String    @unique
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  user    User? // campo oposto da relação 1:1
  Teacher Teacher?

  @@map("person")
}

model User {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  password   String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  id_person  Int       @unique
  person     Person    @relation(fields: [id_person], references: [id])

  @@map("user")
}

model Class {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @default(uuid())
  name        String
  idade_in    Int
  idade_fn    Int
  bo_situacao Boolean        @default(true) // ativo por padrão
  created_at  DateTime       @default(now()) // data atual
  teachers    ClassTeacher[] // relação via pivot
}

model Teacher {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @default(uuid())
  id_person   Int            @unique
  bo_situacao Boolean        @default(true) // ativo por padrão
  created_at  DateTime       @default(now()) // data atual
  person      Person         @relation(fields: [id_person], references: [id])
  classes     ClassTeacher[]
}

model ClassTeacher {
  id         Int    @id @default(autoincrement())
  uuid       String @unique @default(uuid())
  id_teacher Int
  id_class   Int

  teacher Teacher @relation(fields: [id_teacher], references: [id])
  class   Class   @relation(fields: [id_class], references: [id])

  @@unique([id_teacher, id_class]) // evita duplicados
}
