generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id                  Int            @id @default(autoincrement())
  uuid                String         @unique @default(uuid())
  name                String
  cpf                 String         @unique
  phone               String
  dt_nasc             DateTime
  sexo                String
  situacao            Boolean        @default(true)
  email               String         @unique
  created_at          DateTime?      @default(now())
  updated_at          DateTime?      @updatedAt
  ClassSessionPerson  ClassSession[] @relation("PersonClassSessions")
  ClassSessionTeacher ClassSession[] @relation("TeacherClassSessions")
  Lesson              Lesson[]
  student             Student?
  Teacher             Teacher?
  user                User?

  @@map("person")
}

model User {
  id                 Int       @id @default(autoincrement())
  uuid               String    @unique @default(uuid())
  password           String
  created_at         DateTime? @default(now())
  updated_at         DateTime? @updatedAt
  id_person          Int       @unique
  custom_permissions String[]  @default([])
  role               String    @default("viewer")
  person             Person    @relation(fields: [id_person], references: [id])
  password_reset_tokens PasswordResetToken[]

  @@map("user")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  id_user    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user User @relation(fields: [id_user], references: [id])

  @@index([id_user])
  @@index([expires_at])
  @@map("password_reset_token")
}

model Class {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique @default(uuid())
  name           String
  idade_in       Int
  idade_fn       Int
  bo_situacao    Boolean        @default(true)
  created_at     DateTime       @default(now())
  academicYearId Int?
  description    String?        @db.VarChar(500)
  AcademicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  ClassSession   ClassSession[]
  ClassStudent   ClassStudent[]
  teachers       ClassTeacher[]
  Lesson         Lesson[]

  @@map("class")
}

model Teacher {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @default(uuid())
  id_person   Int            @unique
  bo_situacao Boolean        @default(true)
  created_at  DateTime       @default(now())
  classes     ClassTeacher[]
  person      Person         @relation(fields: [id_person], references: [id])

  @@map("teacher")
}

model ClassTeacher {
  id         Int     @id @default(autoincrement())
  uuid       String  @unique @default(uuid())
  id_teacher Int
  id_class   Int
  class      Class   @relation(fields: [id_class], references: [id])
  teacher    Teacher @relation(fields: [id_teacher], references: [id])

  @@unique([id_teacher, id_class])
  @@map("class_teacher")
}

model Student {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @default(uuid())
  id_person   Int            @unique
  created_at  DateTime?      @default(now())
  bo_situacao Boolean        @default(true)
  classes     ClassStudent[]
  person      Person         @relation(fields: [id_person], references: [id])

  @@map("student")
}

model ClassStudent {
  id         Int     @id @default(autoincrement())
  uuid       String  @unique @default(uuid())
  id_student Int
  id_class   Int
  class      Class   @relation(fields: [id_class], references: [id])
  student    Student @relation(fields: [id_student], references: [id])

  @@unique([id_student, id_class])
  @@map("class_student")
}

model ClassSession {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  id_class   Int
  dt_session DateTime
  nr_lesson  Int
  topic      String   @db.VarChar(255)
  id_teacher Int
  notes      String?  @db.VarChar(500)
  id_person  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  class      Class    @relation(fields: [id_class], references: [id])
  person     Person   @relation("PersonClassSessions", fields: [id_person], references: [id])
  teacher    Person   @relation("TeacherClassSessions", fields: [id_teacher], references: [id])

  @@map("class_session")
}

model Lesson {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  id_class         Int
  dt_lesson        DateTime
  nr_lesson        Int
  title            String         @db.VarChar(255)
  description      String?        @db.VarChar(500)
  id_period        Int
  id_person_create Int
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  class            Class          @relation(fields: [id_class], references: [id])
  period           AcademicPeriod @relation(fields: [id_period], references: [id])
  creator          Person         @relation(fields: [id_person_create], references: [id])

  @@map("lesson")
}

model AcademicYear {
  id               Int              @id @default(autoincrement())
  uuid             String           @unique @default(uuid())
  year             Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  id_person_create Int
  periods          AcademicPeriod[]
  classes          Class[]

  @@map("academic_year")
}

model AcademicPeriod {
  id               Int          @id @default(autoincrement())
  name             String
  dt_start         DateTime
  dt_end           DateTime
  id_academy_year  Int
  id_person_create Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  academicYear     AcademicYear @relation(fields: [id_academy_year], references: [id])
  lessons          Lesson[]

  @@map("academic_period")
}
