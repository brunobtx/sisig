generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id                 Int            @id @default(autoincrement())
  uuid               String         @unique @default(uuid())
  name               String
  cpf                String         @unique
  phone              String
  dt_nasc            DateTime
  sexo               String
  situacao           Boolean        @default(true)
  email              String         @unique
  id_organization    Int?
  created_at         DateTime?      @default(now())
  updated_at         DateTime?      @updatedAt
  ClassSessionPerson ClassSession[] @relation("PersonClassSessions")
  Lesson             Lesson[]
  student            Student?
  Teacher            Teacher?
  user               User?
  organization       Organization?  @relation(fields: [id_organization], references: [id])

  @@index([id_organization])
  @@map("person")
}

model User {
  id                    Int                      @id @default(autoincrement())
  uuid                  String                   @unique @default(uuid())
  password              String
  created_at            DateTime?                @default(now())
  updated_at            DateTime?                @updatedAt
  id_person             Int                      @unique
  role                  String                   @default("viewer")
  person                Person                   @relation(fields: [id_person], references: [id])
  permissionGroups      UserPermissionGroup[]
  organizationAccesses  UserOrganizationAccess[]
  password_reset_tokens PasswordResetToken[]

  @@map("user")
}

model Service {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  code        String       @unique
  name        String
  created_at  DateTime     @default(now())
  features    Feature[]
  permissions Permission[]

  @@map("service")
}

model Feature {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid())
  service_id  Int
  code        String
  name        String
  created_at  DateTime     @default(now())
  service     Service      @relation(fields: [service_id], references: [id])
  permissions Permission[]

  @@unique([service_id, code])
  @@map("feature")
}

model Permission {
  id               Int                         @id @default(autoincrement())
  uuid             String                      @unique @default(uuid())
  key              String                      @unique
  service_id       Int
  feature_id       Int
  created_at       DateTime                    @default(now())
  service          Service                     @relation(fields: [service_id], references: [id])
  feature          Feature                     @relation(fields: [feature_id], references: [id])
  groupPermissions PermissionGroupPermission[]

  @@unique([service_id, feature_id])
  @@map("permission")
}

model PermissionGroup {
  id              Int                         @id @default(autoincrement())
  uuid            String                      @unique @default(uuid())
  name            String                      @unique
  description     String?
  is_active       Boolean                     @default(true)
  created_at      DateTime                    @default(now())
  updated_at      DateTime                    @updatedAt
  permissions     PermissionGroupPermission[]
  userAssignments UserPermissionGroup[]

  @@map("permission_group")
}

model PermissionGroupPermission {
  id                  Int             @id @default(autoincrement())
  permission_group_id Int
  permission_id       Int
  permissionGroup     PermissionGroup @relation(fields: [permission_group_id], references: [id])
  permission          Permission      @relation(fields: [permission_id], references: [id])

  @@unique([permission_group_id, permission_id])
  @@map("permission_group_permission")
}

model UserPermissionGroup {
  id                  Int             @id @default(autoincrement())
  user_id             Int
  permission_group_id Int
  user                User            @relation(fields: [user_id], references: [id])
  permissionGroup     PermissionGroup @relation(fields: [permission_group_id], references: [id])

  @@unique([user_id, permission_group_id])
  @@map("user_permission_group")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  id_user    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user User @relation(fields: [id_user], references: [id])

  @@index([id_user])
  @@index([expires_at])
  @@map("password_reset_token")
}

model Class {
  id              Int           @id @default(autoincrement())
  uuid            String        @unique @default(uuid())
  name            String
  idade_in        Int
  idade_fn        Int
  id_organization Int?
  bo_situacao     Boolean       @default(true)
  created_at      DateTime      @default(now())
  description     String?       @db.VarChar(500)
  organization    Organization? @relation(fields: [id_organization], references: [id])
  turmas          Turma[]

  @@index([id_organization])
  @@map("class")
}

model Teacher {
  id            Int            @id @default(autoincrement())
  uuid          String         @unique @default(uuid())
  id_person     Int            @unique
  bo_situacao   Boolean        @default(true)
  created_at    DateTime       @default(now())
  turmas        TurmaTeacher[]
  classSessions ClassSession[]
  person        Person         @relation(fields: [id_person], references: [id])

  @@map("teacher")
}

model TurmaTeacher {
  id         Int     @id @default(autoincrement())
  uuid       String  @unique @default(uuid())
  id_teacher Int
  id_turma   Int
  turma      Turma   @relation(fields: [id_turma], references: [id])
  teacher    Teacher @relation(fields: [id_teacher], references: [id])

  @@unique([id_teacher, id_turma])
  @@map("turma_teacher")
}

model Student {
  id          Int                      @id @default(autoincrement())
  uuid        String                   @unique @default(uuid())
  id_person   Int                      @unique
  created_at  DateTime?                @default(now())
  bo_situacao Boolean                  @default(true)
  turmas      TurmaStudent[]
  attendances ClassSessionAttendance[]
  person      Person                   @relation(fields: [id_person], references: [id])

  @@map("student")
}

model TurmaStudent {
  id         Int     @id @default(autoincrement())
  uuid       String  @unique @default(uuid())
  id_student Int
  id_turma   Int
  turma      Turma   @relation(fields: [id_turma], references: [id])
  student    Student @relation(fields: [id_student], references: [id])

  @@unique([id_student, id_turma])
  @@map("turma_student")
}

model Turma {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  id_class         Int
  id_academic_year Int
  id_organization  Int?
  bo_situacao      Boolean        @default(true)
  created_at       DateTime       @default(now())
  class            Class          @relation(fields: [id_class], references: [id])
  academicYear     AcademicYear   @relation(fields: [id_academic_year], references: [id])
  organization     Organization?  @relation(fields: [id_organization], references: [id])
  teachers         TurmaTeacher[]
  students         TurmaStudent[]
  classSessions    ClassSession[]
  lessons          Lesson[]

  @@unique([id_class, id_academic_year])
  @@index([id_organization])
  @@map("turma")
}

model ClassSession {
  id          Int                      @id @default(autoincrement())
  uuid        String                   @unique @default(uuid())
  id_turma    Int
  dt_session  DateTime
  nr_lesson   Int
  trimester   Int
  topic       String                   @db.VarChar(255)
  id_teacher  Int
  notes       String?                  @db.VarChar(500)
  id_person   Int
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  turma       Turma                    @relation(fields: [id_turma], references: [id])
  person      Person                   @relation("PersonClassSessions", fields: [id_person], references: [id])
  teacher     Teacher                  @relation(fields: [id_teacher], references: [id])
  attendances ClassSessionAttendance[]

  @@unique([id_turma, nr_lesson])
  @@map("class_session")
}

model ClassSessionAttendance {
  id               Int          @id @default(autoincrement())
  uuid             String       @unique @default(uuid())
  id_class_session Int
  id_student       Int
  is_present       Boolean
  notes            String?      @db.VarChar(500)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  classSession     ClassSession @relation(fields: [id_class_session], references: [id])
  student          Student      @relation(fields: [id_student], references: [id])

  @@unique([id_class_session, id_student])
  @@index([id_class_session])
  @@index([id_student])
  @@map("class_session_attendance")
}

model Lesson {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  id_turma         Int
  dt_lesson        DateTime
  nr_lesson        Int
  title            String         @db.VarChar(255)
  description      String?        @db.VarChar(500)
  id_period        Int
  id_person_create Int
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  turma            Turma          @relation(fields: [id_turma], references: [id])
  period           AcademicPeriod @relation(fields: [id_period], references: [id])
  creator          Person         @relation(fields: [id_person_create], references: [id])

  @@map("lesson")
}

model AcademicYear {
  id               Int              @id @default(autoincrement())
  uuid             String           @unique @default(uuid())
  year             Int
  id_organization  Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  id_person_create Int
  organization     Organization?    @relation(fields: [id_organization], references: [id])
  periods          AcademicPeriod[]
  turmas           Turma[]

  @@index([id_organization])
  @@map("academic_year")
}

model Organization {
  id            Int                      @id @default(autoincrement())
  uuid          String                   @unique @default(uuid())
  name          String
  type          String
  id_parent     Int?
  bo_situacao   Boolean                  @default(true)
  created_at    DateTime                 @default(now())
  updated_at    DateTime                 @updatedAt
  parent        Organization?            @relation("OrganizationHierarchy", fields: [id_parent], references: [id])
  children      Organization[]           @relation("OrganizationHierarchy")
  people        Person[]
  classes       Class[]
  academicYears AcademicYear[]
  turmas        Turma[]
  userAccesses  UserOrganizationAccess[]

  @@unique([name, id_parent])
  @@index([id_parent])
  @@map("organization")
}

model UserOrganizationAccess {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid())
  id_user         Int
  id_organization Int
  scope           String       @default("organization")
  is_default      Boolean      @default(false)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  user            User         @relation(fields: [id_user], references: [id])
  organization    Organization @relation(fields: [id_organization], references: [id])

  @@unique([id_user, id_organization, scope])
  @@index([id_user])
  @@index([id_organization])
  @@map("user_organization_access")
}

model AcademicPeriod {
  id               Int          @id @default(autoincrement())
  name             String
  dt_start         DateTime
  dt_end           DateTime
  id_academy_year  Int
  id_person_create Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  academicYear     AcademicYear @relation(fields: [id_academy_year], references: [id])
  lessons          Lesson[]

  @@map("academic_period")
}
